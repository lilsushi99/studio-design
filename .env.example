# ==============================================================================
# KAIJU STUDIOS - PRODUCTION ENVIRONMENT CONFIGURATION (LARAVEL 12 + REVENUE NODES)
# ==============================================================================
# Instructions for Hostinger Deployment:
# 1. Upload this file as '.env' to your public_html / Laravel installation directory.
# 2. Run 'php artisan key:generate' via SSH terminal or supply a secure random 32-character key below.
# 3. Create a MySQL database inside Hostinger hPanel and fill out the DB_* credentials below.
# 4. Set up an FTP / File storage link or symlink ('php artisan storage:link') for media assets.
# ==============================================================================

# -----------------------------
# CORE APPLICATION CONFIG
# -----------------------------
APP_NAME="Kaiju Studios Production Core"
APP_ENV=production
APP_KEY=base64:fH7NOnV48e9FPy8Y6BqK6yD6S6v+f8hFm3z7S2nJmK4=
APP_DEBUG=false
APP_URL="http://localhost:3000"
APP_TIMEZONE=UTC
APP_LOCALE=en

# -----------------------------
# HOSTINGER MYSQL DATABASE
# -----------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kaiju_cms_production
DB_USERNAME=root
DB_PASSWORD=

# -----------------------------
# CACHE, SESSION & QUEUE MANAGEMENT
# -----------------------------
# Hostinger shared servers default to database/file storage for caches/sessions.
# For high performance with Redis, change store name to 'redis'.
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

# -----------------------------
# LARAVEL FILE STORE & STORAGE DRIVERS
# -----------------------------
# Use 'public' disk to automatically write file uploads to 'storage/app/public/media'.
# On Hostinger, ensure public/storage symlinks to storage/app/public.
FILESYSTEM_DISK=public

# -----------------------------
# MAIL DELIVERY SYSTEM
# -----------------------------
# Set up a SMTP mailer via Hostinger Titan Mail or external SMTP (e.g. Mailgun, SendGrid)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@kaijustudios.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------
# SECURE AUTHENTICATION (LARAVEL SANCTUM)
# -----------------------------
SANCTUM_STATEFUL_DOMAINS="localhost:3000,127.0.0.1:3000"

# -----------------------------
# GOOGLE AI CORE INTEGRATIONS
# -----------------------------
# Supply your Google Gemini API key here to power server-side AI-assisted services
GEMINI_API_KEY=""

# -----------------------------
# FRONTEND / VITE PARAMETERS
# -----------------------------
# Tells the React front-end where the server REST API root lies
VITE_API_URL="/api"
